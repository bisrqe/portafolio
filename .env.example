# Cloudinary Configuration
# Sign up for free at https://cloudinary.com

# Your Cloudinary Cloud Name
VITE_CLOUDINARY_CLOUD_NAME=dobiuvljw

# Your Cloudinary Upload Preset (create in dashboard)
VITE_CLOUDINARY_UPLOAD_PRESET=personal-portfolio

# Firebase Configuration
# Get these from your Firebase project settings
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Admin Password
# Change this to a secure password for accessing add/delete features
VITE_ADMIN_PASSWORD=admin123

# Admin Email
# The Google account email allowed to access the admin dashboard
VITE_ADMIN_EMAIL=your@gmail.com
